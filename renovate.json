{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "enabledManagers": ["docker-compose"],
  "includePaths": ["apps/**"],
  "prCreation": "immediate",
  "postUpgradeTasks": {
    "commands": ["bash .github/workflows/renovate-app-version.sh"],
    "fileFilters": ["apps/**"],
    "executionMode": "branch"
  }
}
